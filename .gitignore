# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environment ──
.venv/
venv/
env/
ENV/

# ── Environment / Secrets ──
.env
*.pem
*.key

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Medium Article (private — not for public repo) ──
docs/MEDIUM_ARTICLE.md

# ── Logs & Temp ──
*.log
tmp/
temp/

# ── Docker ──
docker-compose.override.yml

# ── OS ──
Thumbs.db
.DS_Store
