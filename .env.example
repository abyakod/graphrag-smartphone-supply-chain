# ═══════════════════════════════════════════════════
# PhoneGraph Environment Variables
# Copy to .env: cp .env.example .env
# ═══════════════════════════════════════════════════

# ── LLM Provider: Ollama (local, free — recommended) ──
# Install Ollama: https://ollama.com/download
# Then: ollama pull llama3
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── LLM Provider: OpenAI (cloud, optional fallback) ──
# Only needed if Ollama is not available
OPENAI_API_KEY=your-openai-api-key-here

# ── Memgraph Connection ──
MEMGRAPH_HOST=127.0.0.1
MEMGRAPH_PORT=7687

# ── API ──
API_BASE_URL=http://localhost:8000

# ── Logging ──
LOG_LEVEL=INFO
